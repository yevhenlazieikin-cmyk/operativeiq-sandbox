{
  "name": "backoffice-shared-ui-root",
  "version": "0.1.1",
  "scripts": {
    "ng": "ng",
    "start": "npm run sprites && ng serve demo-host --port=4500",
    "build": "npm run sprites && ng build demo-host",
    "watch": "ng build demo-host --watch --configuration development",
    "test": "ng test demo-host",
    "build:lib": "ng build backoffice-shared-ui",
    "build:demo": "ng build demo-host",
    "serve:demo": "ng serve demo-host --port 4500 --hmr",
    "pack": "npm run build:lib && cd dist/backoffice-shared-ui && npm pack --pack-destination ../../",
    "check": "npm run prettier:check && npm run lint",
    "lint": "ng lint",
    "lint:all": "npm run lint:scss && npm run lint:ts && npm run lint:html",
    "lint:all:fix": "npm run lint:ts:fix && npm run lint:html:fix && npm run lint:scss:fix",
    "lint:scss": "npx stylelint \"projects/backoffice-shared-ui/src/**/*.scss\" \"projects/demo-host/src/**/*.scss\"",
    "lint:scss:fix": "npx stylelint \"projects/backoffice-shared-ui/src/**/*.scss\" \"projects/demo-host/src/**/*.scss\" --fix",
    "lint:ts": "npx eslint \"projects/backoffice-shared-ui/src/**/*.ts\" \"projects/demo-host/src/**/*.ts\" --quiet",
    "lint:ts:fix": "npx eslint \"projects/backoffice-shared-ui/src/**/*.ts\" \"projects/demo-host/src/**/*.ts\" --quiet --fix",
    "lint:html": "npx eslint \"projects/backoffice-shared-ui/src/**/*.html\" \"projects/demo-host/src/**/*.html\"",
    "lint:html:fix": "npx eslint \"projects/backoffice-shared-ui/src/**/*.html\" \"projects/demo-host/src/**/*.html\" --fix",
    "prettier": "prettier --write \"projects/backoffice-shared-ui/src/**/*.{ts,js,json,scss,html}\" \"projects/demo-host/src/**/*.{ts,js,json,scss,html}\"",
    "prettier:check": "prettier --list-different \"projects/backoffice-shared-ui/src/**/*.{ts,js,json,scss,html}\" \"projects/demo-host/src/**/*.{ts,js,json,scss,html}\"",
    "postinstall": "husky",
    "sprites": "svg-sprite --config sprite-config.json --dest projects/demo-host/assets/sprites --css-dest . \"projects/demo-host/assets/images/icon/*.svg\" \"projects/backoffice-shared-ui/assets/images/icon/*.svg\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.4",
    "@angular/common": "^20.3.4",
    "@angular/compiler": "^20.3.4",
    "@angular/core": "^20.3.4",
    "@angular/elements": "^20.3.4",
    "@angular/forms": "^20.3.4",
    "@angular/material-moment-adapter": "^20.2.3",
    "@angular/platform-browser": "^20.3.4",
    "@angular/router": "^20.3.4",
    "@ngneat/input-mask": "^6.1.0",
    "@webcomponents/custom-elements": "^1.6.0",
    "cropperjs": "^2.1.0",
    "inputmask": "^5.0.9",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.17.21",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "ng-qrcode": "^20.0.1",
    "ngx-cookie-service": "^20.1.1",
    "overlayscrollbars-ngx": "^0.5.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.4",
    "@angular/cdk": "^20.2.3",
    "@angular/cli": "^20.3.4",
    "@angular/compiler-cli": "^20.3.4",
    "@angular/material": "^20.2.3",
    "@eslint/js": "^9.35.0",
    "@types/inputmask": "^5.0.7",
    "@types/jasmine": "~5.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/moment": "^2.11.29",
    "@types/moment-timezone": "^0.5.13",
    "angular-eslint": "20.3.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.1.6",
    "ng-packagr": "^20.3.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "stylelint": "^16.24.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "svg-sprite": "^2.0.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.40.0"
  }
}
